@if (User.HasClaim(
"urn:action:permission",
"create"))
{

    <a asp-action="Create">

        Nuevo Producto

    </a>

}
@model List<Domain.Entities.Product>


@{
    ViewData["Title"] = "Productos";
}



<div class="container">
    <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
        <div>
            <h2><i class="bi bi-box-seam-fill me-2 text-primary"></i>Productos</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Productos</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <div class="search-wrapper">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="form-control" id="searchInput" placeholder="Buscar productos..." onkeyup="filterTable()">
            </div>
            <span class="badge bg-soft-info fs-6 px-3 py-2" id="totalCount">
                <i class="bi bi-list-ol me-1"></i> @Model.Count productos
            </span>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="content-card text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem; color: var(--gray-300);"></i>
            <h4 class="mt-3 text-muted">No hay productos registrados</h4>
            <p class="text-muted">Comienza agregando productos al catálogo.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-modern" id="productTable">
                <thead>
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">Descripción</th>
                        <th scope="col">Precio</th>
                        <th scope="col">Costo</th>
                        <th scope="col">Margen</th>
                        <th scope="col">Stock</th>
                        <th scope="col">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model)
                    {
                        <tr>
                            <td><span class="fw-semibold text-muted">#@producto.ProductID</span></td>
                            <td>
                                <span class="fw-semibold">@producto.Name</span>
                            </td>
                            <td class="text-muted" style="max-width: 220px;">
                                @(producto.Description?.Length > 50 ? producto.Description[..50] + "..." : producto.Description ?? "-")
                            </td>
                            <td>
                                <span class="badge badge-price">
                                    $@producto.UnitPrice?.ToString("N2")
                                </span>
                            </td>
                            <td class="text-muted">$@producto.UnitCost?.ToString("N2")</td>
                            <td>
                                @if (producto.ProfitMargin.HasValue)
                                {
                                    var color = producto.ProfitMargin >= 40 ? "bg-soft-success" :
                                    producto.ProfitMargin >= 20 ? "bg-soft-primary" :
                                    producto.ProfitMargin >= 0 ? "bg-soft-warning" : "bg-soft-danger";
                                    <span class="badge badge-modern @color">
                                        @producto.ProfitMargin.Value.ToString("F1")%
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @{
                                    var stock = producto.Stock ?? 0;
                                    var stockBadge = stock > 20 ? "badge-stock-high" :
                                    stock > 5 ? "badge-stock-medium" : "badge-stock-low";
                                    var stockIcon = stock > 20 ? "bi-check-circle-fill" :
                                    stock > 5 ? "bi-exclamation-circle-fill" : "bi-x-circle-fill";
                                }
                                <span class="badge badge-modern @stockBadge">
                                    <i class="bi @stockIcon me-1"></i> @stock
                                </span>
                            </td>
                            <td>
                                @if (producto.Active && !producto.Discontinued)
                                {
                                    <span class="badge badge-modern bg-soft-success">
                                        <i class="bi bi-check-circle-fill me-1"></i> Activo
                                    </span>
                                }
                                else if (producto.Discontinued)
                                {
                                    <span class="badge badge-modern bg-soft-danger">
                                        <i class="bi bi-x-circle-fill me-1"></i> Descontinuado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-modern bg-soft-warning">
                                        <i class="bi bi-pause-circle-fill me-1"></i> Inactivo
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <small class="text-muted" id="resultCount">Mostrando @Model.Count producto(s)</small>
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterTable() {
            const input = document.getElementById('searchInput');
            const filter = input.value.toLowerCase();
            const table = document.getElementById('productTable');
            if (!table) return;
            const rows = table.getElementsByTagName('tr');
            let visibleCount = 0;

            for (let i = 0; i < rows.length; i++) {
                const row = rows[i];
                if (row.parentElement.tagName === 'THEAD') continue;
                const text = row.textContent.toLowerCase();
                if (text.includes(filter)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            }

            const countEl = document.getElementById('resultCount');
            if (countEl) countEl.textContent = 'Mostrando ' + visibleCount + ' producto(s)';

            const totalEl = document.getElementById('totalCount');
            if (totalEl) totalEl.innerHTML = '<i class="bi bi-list-ol me-1"></i> ' + visibleCount + ' productos';
        }
    </script>
}
